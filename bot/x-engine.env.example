# ── FLAGENT X ENGINE — Additional env vars ──
# Add these to the MAIN Railway service alongside existing bot vars

# Twitter API (already set — listed for reference)
# TWITTER_API_KEY=...
# TWITTER_API_SECRET=...
# TWITTER_ACCESS_TOKEN=...
# TWITTER_ACCESS_SECRET=...
# TWITTER_BEARER_TOKEN=...

# Dune Analytics (already set — listed for reference)
# DUNE_API_KEY=...

# Anthropic (already set — shared with main bot)
# ANTHROPIC_API_KEY=...

# Supabase (already set — shared with main bot)
# SUPABASE_SERVICE_KEY=...

# ── X Engine Config (optional, has defaults) ──
X_POST_INTERVAL_MIN=45       # minutes between autonomous tweets (default: 45)
X_MENTION_CHECK_MS=120000    # ms between mention checks (default: 120000 = 2 min)

# ── Dune Query IDs (create these in Dune, paste IDs here) ──
# DUNE_QUERY_BSC_HEALTH=0        # BSC daily txns, active addresses, gas
# DUNE_QUERY_FOURMEME=0          # Four.Meme launches, graduations, volume
# DUNE_QUERY_CATEGORIES=0        # Token category performance (AI/Chinese/animal/political)
# DUNE_QUERY_SMART_MONEY=0       # Top wallets by win rate
# DUNE_QUERY_FLAP=0              # Flap.sh launches + volume
