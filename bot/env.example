# ── FLAGENT BOT ENV ──

# BSC wallet private key (fresh wallet, fund with BNB)
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# BSC RPC (default works, QuickNode or Ankr is faster)
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Supabase 4Gent project — get service_role key from:
# https://supabase.com/dashboard/project/seartddspffufwiqzwvh/settings/api
SUPABASE_SERVICE_KEY=eyJ_YOUR_SERVICE_ROLE_KEY_HERE

# Claude Sonnet 4 — powers the agent's thoughts/personality
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-_YOUR_KEY_HERE

# ── Trading Config ──
BUY_AMOUNT_BNB=0.01
MAX_POSITIONS=5
TAKE_PROFIT_1=2.0
TAKE_PROFIT_2=3.0
STOP_LOSS=0.6
TIME_STOP_MINUTES=30
